{{!
    @template assignsubmission_genaiuse/view_student

    Renders the submission summary for the student-facing view. Uses the same
    card aesthetic as the submission form (.submission_genaiuse_card) so the
    student sees a layout that mirrors what they filled in.

    Context variables required for this template:
    * aiused - bool, true when the student declared AI was used.
    * aitoolsused - string (already escaped), AI systems and links used.
    * aiusecontext - string (already escaped), specific use of AI.
    * aicontentdesc - string (already escaped), content provided by AI.
    * aimodification - string (already escaped), how output was modified.
    * declarationtitle - string, heading for declaration card.
    * noaiusedtext - string, plain-text noaiused message.
    * label_tools/label_context/label_content/label_modification - string,
      labels for the four AI detail fields.
    * hastooluse - bool, true when there is a rich text tool use block.
    * tooluseformatted - string (raw HTML), formatted tool use rich text.
    * tooluseheading - string, heading for tool use card.
    * toolusefiles - string (raw HTML), file list for tool use file area.
    * supportingevidenceheading - string, heading for supporting evidence card.
    * evidencechoicelabel - string, friendly choice label.
    * hasevidencefiles - bool, true when files should be shown.
    * evidencefiles - string (raw HTML), file list for evidence file area.
    * hasonedrivesection - bool, true to render the OneDrive card.
    * onedriveheading - string, heading for OneDrive card.
    * hasonedrivechoice - bool, true when a yes/no label should be shown.
    * onedrivechoicelabel - string, friendly choice label.
    * hasonedrivelink - bool, true when a OneDrive link is present.
    * onedrivelinkhtml - string (raw HTML), anchor tag for OneDrive link.

    Example context (json):
    {
        "aiused": true,
        "aitoolsused": "ChatGPT (https://chat.openai.com)",
        "aiusecontext": "brainstorming ideas and generating draft text",
        "aicontentdesc": "an outline structure and sample paragraphs",
        "aimodification": "rewrote key sections and verified facts",
        "declarationtitle": "Generative AI use statement - Declaration",
        "noaiusedtext": "No AI Used",
        "label_tools": "AI system(s) and link(s)",
        "label_context": "Specific use",
        "label_content": "Content provided by AI",
        "label_modification": "How output was modified",
        "hastooluse": true,
        "tooluseformatted": "<p>Tool use details...</p>",
        "tooluseheading": "Generative AI use statement - Tool use",
        "toolusefiles": "",
        "supportingevidenceheading": "Generative AI use statement - Supporting evidence",
        "evidencechoicelabel": "Yes, I have supporting evidence",
        "hasevidencefiles": true,
        "evidencefiles": "",
        "hasonedrivesection": true,
        "onedriveheading": "Generative AI use statement - OneDrive link",
        "hasonedrivechoice": true,
        "onedrivechoicelabel": "Yes, I have a OneDrive link",
        "hasonedrivelink": true,
        "onedrivelinkhtml": "<a href=\"https://example.com/onedrive\" target=\"_blank\">OneDrive link (opens in new window)</a>"
    }
}}
<div class="submission_genaiuse submission_genaiuse_view submission_genaiuse_view_student">
    <div class="card submission_genaiuse_card mb-3">
        <div class="card-header submission_genaiuse_cardheader">
            <h4 class="submission_genaiuse_cardtitle h6 mb-0">{{declarationtitle}}</h4>
        </div>
        <div class="card-body">
            {{#aiused}}
                <dl class="genaiuse_view_dl">
                    <dt>{{label_tools}}:</dt>
                    <dd>{{aitoolsused}}</dd>
                    <dt>{{label_context}}:</dt>
                    <dd>{{aiusecontext}}</dd>
                    <dt>{{label_content}}:</dt>
                    <dd>{{aicontentdesc}}</dd>
                    <dt>{{label_modification}}:</dt>
                    <dd>{{aimodification}}</dd>
                </dl>
            {{/aiused}}
            {{^aiused}}
                <p class="mb-0">{{noaiusedtext}}</p>
            {{/aiused}}
        </div>
    </div>

    {{#aiused}}
        <div class="card submission_genaiuse_card mb-3 genaiuse_tooluse_popout_wrapper">
            <div class="card-header submission_genaiuse_cardheader d-flex justify-content-between align-items-center">
                <h4 class="submission_genaiuse_cardtitle h6 mb-0">{{tooluseheading}}</h4>
                {{#hastooluse}}
                    <a href="#" class="genaiuse_tooluse_popout_button"
                       data-region="genaiuse-tooluse-popout"
                       aria-label="{{#str}}togglezoom, mod_assign{{/str}}"
                       title="{{#str}}togglezoom, mod_assign{{/str}}">
                        {{#pix}}e/fullscreen, core{{/pix}}
                    </a>
                {{/hastooluse}}
            </div>
            <div class="card-body">
                {{#hastooluse}}
                    <div class="genaiuse_tooluse_text">{{{tooluseformatted}}}</div>
                {{/hastooluse}}
                {{{toolusefiles}}}
            </div>
        </div>
        {{#hastooluse}}
            {{#js}}
                require(['assignsubmission_genaiuse/tooluse_popout'], function(Popout) {
                    Popout.init();
                });
            {{/js}}
        {{/hastooluse}}
    {{/aiused}}

    <div class="card submission_genaiuse_card mb-3">
        <div class="card-header submission_genaiuse_cardheader">
            <h4 class="submission_genaiuse_cardtitle h6 mb-0">{{supportingevidenceheading}}</h4>
        </div>
        <div class="card-body">
            {{#hasevidencefiles}}
                {{{evidencefiles}}}
            {{/hasevidencefiles}}
            {{^hasevidencefiles}}
                <p class="mb-0">{{evidencechoicelabel}}</p>
            {{/hasevidencefiles}}
        </div>
    </div>

    {{#hasonedrivesection}}
        <div class="card submission_genaiuse_card mb-3">
            <div class="card-header submission_genaiuse_cardheader">
                <h4 class="submission_genaiuse_cardtitle h6 mb-0">{{onedriveheading}}</h4>
            </div>
            <div class="card-body">
                {{#hasonedrivechoice}}
                    <p {{^hasonedrivelink}}class="mb-0"{{/hasonedrivelink}}>{{onedrivechoicelabel}}</p>
                {{/hasonedrivechoice}}
                {{#hasonedrivelink}}
                    <p class="mb-0">{{{onedrivelinkhtml}}}</p>
                {{/hasonedrivelink}}
            </div>
        </div>
    {{/hasonedrivesection}}
</div>
